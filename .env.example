# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth — generate with: openssl rand -hex 32
NEXTAUTH_SECRET=replace-with-a-random-64-char-hex-string
NEXTAUTH_URL=http://localhost:3000

# Admin credentials
ADMIN_EMAIL=admin@yourdomain.com
# Use ADMIN_PASSWORD_HASH (bcrypt) in production; ADMIN_PASSWORD (plain) is dev-only
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash
ADMIN_PASSWORD=

# Upstash Redis — distributed rate limiting (production)
# Leave unset in local dev; the app falls back to in-process rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App environment
NODE_ENV=development
